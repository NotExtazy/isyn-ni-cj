<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <rewrite>
            <rules>
                <!-- Rule to redirect all requests to router.php except for existing files and directories -->
                <rule name="Router" stopProcessing="true">
                    <match url="^(.*)$" ignoreCase="false" />
                    <conditions>
                        <!-- Don't rewrite requests for existing files -->
                        <add input="{REQUEST_FILENAME}" matchType="IsFile" ignoreCase="false" negate="true" />
                        <!-- Don't rewrite requests for existing directories -->
                        <add input="{REQUEST_FILENAME}" matchType="IsDirectory" ignoreCase="false" negate="true" />
                        <!-- Don't rewrite requests for the router itself -->
                        <add input="{REQUEST_FILENAME}" pattern="^router\.php$" ignoreCase="false" negate="true" />
                        <!-- Don't rewrite requests for login.php -->
                        <add input="{REQUEST_FILENAME}" pattern="^login\.php$" ignoreCase="false" negate="true" />
                        <!-- Don't rewrite requests for assets (css, js, images) -->
                        <add input="{REQUEST_FILENAME}" pattern="^assets/" ignoreCase="false" negate="true" />
                        <!-- Don't rewrite requests for process files -->
                        <add input="{REQUEST_FILENAME}" pattern="^process/" ignoreCase="false" negate="true" />
                        <!-- Don't rewrite requests for routes files -->
                        <add input="{REQUEST_FILENAME}" pattern="^routes/" ignoreCase="false" negate="true" />
                        <!-- Don't rewrite requests for includes files -->
                        <add input="{REQUEST_FILENAME}" pattern="^includes/" ignoreCase="false" negate="true" />
                        <!-- Don't rewrite requests for reports files -->
                        <add input="{REQUEST_FILENAME}" pattern="^reports/" ignoreCase="false" negate="true" />
                    </conditions>
                    <action type="Rewrite" url="router.php" appendQueryString="true" />
                </rule>
            </rules>
        </rewrite>
        <defaultDocument>
            <files>
                <clear />
                <add value="router.php" />
            </files>
        </defaultDocument>
    </system.webServer>
</configuration>
